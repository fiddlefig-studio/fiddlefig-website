# production, preview or development
APP_ENVIRONMENT=production
APP_DOMAIN=https://mysite.com
APP_PROTOCOL=https://

# See https://github.com/unjs/consola
APP_LOG_LEVEL=3

# Contact form delivery
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
CONTACT_BCC_EMAIL=
CONTACT_RATE_LIMIT_WINDOW=900
CONTACT_RATE_LIMIT_MAX=5

# Google reCAPTCHA v3 — public site key plus secret for server verification
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Optional threshold 0–1 (default 0.5); lower accepts more requests
RECAPTCHA_MIN_SCORE=0.5
